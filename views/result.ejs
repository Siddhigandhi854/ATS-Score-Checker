<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ATS Analysis Results - Resume Checker</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            padding: 2rem 0;
        }
        
        .result-card {
            background: rgba(255, 255, 255, 0.95);
            border-radius: 20px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
            padding: 2rem;
            backdrop-filter: blur(10px);
            margin-bottom: 2rem;
        }
        
        .score-section {
            text-align: center;
            padding: 2rem;
            background: linear-gradient(135deg, #f8f9ff 0%, #e8f4fd 100%);
            border-radius: 15px;
            margin-bottom: 2rem;
        }
        
        .score-circle {
            width: 200px;
            height: 200px;
            margin: 0 auto 1.5rem;
            position: relative;
        }
        
        .score-circle svg {
            transform: rotate(-90deg);
        }
        
        .score-circle .score-text {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 3rem;
            font-weight: bold;
        }
        
        .score-excellent { color: #28a745; }
        .score-good { color: #17a2b8; }
        .score-average { color: #ffc107; }
        .score-poor { color: #dc3545; }
        
        .section-card {
            background: white;
            border-radius: 15px;
            padding: 1.5rem;
            margin-bottom: 1.5rem;
            border-left: 4px solid;
            transition: transform 0.3s ease;
        }
        
        .section-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
        }
        
        .strengths-card { border-left-color: #28a745; }
        .weaknesses-card { border-left-color: #dc3545; }
        .suggestions-card { border-left-color: #17a2b8; }
        .keywords-card { border-left-color: #ffc107; }
        .issues-card { border-left-color: #fd7e14; }
        
        .section-title {
            font-size: 1.25rem;
            font-weight: 600;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
        }
        
        .section-icon {
            font-size: 1.5rem;
            margin-right: 0.5rem;
        }
        
        .list-item {
            padding: 0.5rem 0;
            border-bottom: 1px solid #f0f0f0;
            display: flex;
            align-items: flex-start;
        }
        
        .list-item:last-child {
            border-bottom: none;
        }
        
        .list-icon {
            margin-right: 0.75rem;
            margin-top: 0.25rem;
            opacity: 0.7;
        }
        
        .badge-custom {
            padding: 0.5rem 1rem;
            border-radius: 20px;
            font-weight: 500;
            margin: 0.25rem;
            display: inline-block;
        }
        
        .back-btn {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
            padding: 12px 30px;
            border-radius: 25px;
            color: white;
            font-weight: 600;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }
        
        .back-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
            color: white;
        }
        
        .progress-ring {
            transition: stroke-dashoffset 1s ease-in-out;
        }
        
        .fade-in {
            animation: fadeIn 0.5s ease-in;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        .empty-state {
            text-align: center;
            padding: 2rem;
            color: #6c757d;
        }
        
        .empty-state i {
            font-size: 3rem;
            margin-bottom: 1rem;
            opacity: 0.5;
        }
        
        /* Print-specific styles */
        @media print {
            body {
                background: white !important;
                padding: 0 !important;
            }
            
            .result-card {
                background: white !important;
                box-shadow: none !important;
                border: 1px solid #ddd !important;
                page-break-inside: avoid;
            }
            
            .section-card {
                background: white !important;
                border: 1px solid #ddd !important;
                page-break-inside: avoid;
            }
            
            .alert {
                background: white !important;
                border: 1px solid #ddd !important;
                color: black !important;
            }
            
            .alert-info {
                background: #f8f9fa !important;
                border: 1px solid #dee2e6 !important;
            }
            
            .back-btn {
                display: none !important;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <!-- Header -->
                <div class="result-card fade-in">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h1 class="display-5 fw-bold text-primary mb-0">
                            <i class="fas fa-chart-line me-3"></i>ATS Analysis Results
                        </h1>
                        <a href="/" class="back-btn">
                            <i class="fas fa-arrow-left me-2"></i>Analyze Another Resume
                        </a>
                    </div>
                    
                    <!-- ATS Score Section -->
                    <div class="score-section">
                        <h2 class="mb-4">ATS Compatibility Score</h2>
                        <div class="score-circle">
                            <svg width="200" height="200">
                                <circle cx="100" cy="100" r="90" stroke="#e9ecef" stroke-width="20" fill="none"/>
                                <circle id="progressRing" cx="100" cy="100" r="90" 
                                        stroke="<%= getScoreColor(analysis.atsScore) %>" 
                                        stroke-width="20" fill="none"
                                        stroke-linecap="round"
                                        stroke-dasharray="<%= 2 * Math.PI * 90 %>"
                                        stroke-dashoffset="<%= 2 * Math.PI * 90 * (1 - analysis.atsScore / 100) %>"
                                        class="progress-ring"/>
                            </svg>
                            <div class="score-text <%= getScoreClass(analysis.atsScore) %>">
                                <%= analysis.atsScore %>%
                            </div>
                        </div>
                        <h3 class="<%= getScoreClass(analysis.atsScore) %>">
                            <%= getScoreMessage(analysis.atsScore) %>
                        </h3>
                        <p class="text-muted">
                            <%= getScoreDescription(analysis.atsScore) %>
                        </p>
                    </div>
                </div>
                
                <!-- Analysis Sections -->
                <div class="row">
                    <!-- Strengths -->
                    <div class="col-lg-6 fade-in">
                        <div class="section-card strengths-card">
                            <div class="section-title">
                                <i class="fas fa-check-circle section-icon text-success"></i>
                                Strengths
                            </div>
                            <% if (analysis.strengths && analysis.strengths.length > 0) { %>
                                <% analysis.strengths.forEach(function(strength) { %>
                                    <div class="list-item">
                                        <i class="fas fa-check text-success list-icon"></i>
                                        <span><%= strength %></span>
                                    </div>
                                <% }); %>
                            <% } else { %>
                                <div class="empty-state">
                                    <i class="fas fa-info-circle"></i>
                                    <p>No specific strengths identified</p>
                                </div>
                            <% } %>
                        </div>
                    </div>
                    
                    <!-- Weaknesses -->
                    <div class="col-lg-6 fade-in">
                        <div class="section-card weaknesses-card">
                            <div class="section-title">
                                <i class="fas fa-exclamation-triangle section-icon text-danger"></i>
                                Areas for Improvement
                            </div>
                            <% if (analysis.weaknesses && analysis.weaknesses.length > 0) { %>
                                <% analysis.weaknesses.forEach(function(weakness) { %>
                                    <div class="list-item">
                                        <i class="fas fa-times text-danger list-icon"></i>
                                        <span><%= weakness %></span>
                                    </div>
                                <% }); %>
                            <% } else { %>
                                <div class="empty-state">
                                    <i class="fas fa-check-circle"></i>
                                    <p>No major weaknesses identified</p>
                                </div>
                            <% } %>
                        </div>
                    </div>
                    
                    <!-- Suggestions -->
                    <div class="col-lg-12 fade-in">
                        <div class="section-card suggestions-card">
                            <div class="section-title">
                                <i class="fas fa-lightbulb section-icon text-info"></i>
                                Recommendations
                            </div>
                            <% if (analysis.suggestions && analysis.suggestions.length > 0) { %>
                                <div class="row">
                                    <% analysis.suggestions.forEach(function(suggestion) { %>
                                        <div class="col-md-6">
                                            <div class="list-item">
                                                <i class="fas fa-arrow-right text-info list-icon"></i>
                                                <span><%= suggestion %></span>
                                            </div>
                                        </div>
                                    <% }); %>
                                </div>
                            <% } else { %>
                                <div class="empty-state">
                                    <i class="fas fa-star"></i>
                                    <p>Your resume looks great! No specific suggestions at this time.</p>
                                </div>
                            <% } %>
                        </div>
                    </div>
                    
                    <!-- Keywords Analysis -->
                    <div class="col-lg-6 fade-in">
                        <div class="section-card keywords-card">
                            <div class="section-title">
                                <i class="fas fa-key section-icon text-warning"></i>
                                Found Keywords
                            </div>
                            <% if (analysis.keywordMatches && analysis.keywordMatches.length > 0) { %>
                                <div>
                                    <% analysis.keywordMatches.forEach(function(keyword) { %>
                                        <span class="badge bg-success badge-custom">
                                            <i class="fas fa-check me-1"></i><%= keyword %>
                                        </span>
                                    <% }); %>
                                </div>
                            <% } else { %>
                                <div class="empty-state">
                                    <i class="fas fa-search"></i>
                                    <p>No specific keywords identified</p>
                                </div>
                            <% } %>
                        </div>
                    </div>
                    
                    <!-- Missing Keywords -->
                    <div class="col-lg-6 fade-in">
                        <div class="section-card keywords-card">
                            <div class="section-title">
                                <i class="fas fa-plus-circle section-icon text-warning"></i>
                                Suggested Keywords
                            </div>
                            <% if (analysis.missingKeywords && analysis.missingKeywords.length > 0) { %>
                                <div>
                                    <% analysis.missingKeywords.forEach(function(keyword) { %>
                                        <span class="badge bg-warning badge-custom">
                                            <i class="fas fa-plus me-1"></i><%= keyword %>
                                        </span>
                                    <% }); %>
                                </div>
                            <% } else { %>
                                <div class="empty-state">
                                    <i class="fas fa-check-circle"></i>
                                    <p>Good keyword coverage</p>
                                </div>
                            <% } %>
                        </div>
                    </div>
                    
                    <!-- Missing Skills -->
                    <% if (analysis.missingSkills && analysis.missingSkills.length > 0) { %>
                    <div class="col-lg-6 fade-in">
                        <div class="section-card issues-card">
                            <div class="section-title">
                                <i class="fas fa-graduation-cap section-icon text-primary"></i>
                                Skills to Consider Adding
                            </div>
                            <% analysis.missingSkills.forEach(function(skill) { %>
                                <div class="list-item">
                                    <i class="fas fa-plus text-primary list-icon"></i>
                                    <span><%= skill %></span>
                                </div>
                            <% }); %>
                        </div>
                    </div>
                    <% } %>
                    
                    <!-- Formatting Issues -->
                    <% if (analysis.formattingIssues && analysis.formattingIssues.length > 0) { %>
                    <div class="col-lg-6 fade-in">
                        <div class="section-card issues-card">
                            <div class="section-title">
                                <i class="fas fa-file-alt section-icon text-secondary"></i>
                                Formatting Issues
                            </div>
                            <% analysis.formattingIssues.forEach(function(issue) { %>
                                <div class="list-item">
                                    <i class="fas fa-exclamation text-secondary list-icon"></i>
                                    <span><%= issue %></span>
                                </div>
                            <% }); %>
                        </div>
                    </div>
                    <% } %>
                    
                    <!-- Grammar Issues -->
                    <% if (analysis.grammarIssues && analysis.grammarIssues.length > 0) { %>
                    <div class="col-lg-12 fade-in">
                        <div class="section-card issues-card">
                            <div class="section-title">
                                <i class="fas fa-spell-check section-icon text-secondary"></i>
                                Grammar & Language
                            </div>
                            <% analysis.grammarIssues.forEach(function(issue) { %>
                                <div class="list-item">
                                    <i class="fas fa-pen text-secondary list-icon"></i>
                                    <span><%= issue %></span>
                                </div>
                            <% }); %>
                        </div>
                    </div>
                    <% } %>
                    
                    <!-- Recommended Changes -->
                    <% if (analysis.recommendedChanges && analysis.recommendedChanges.length > 0) { %>
                    <div class="col-lg-12 fade-in">
                        <div class="section-card suggestions-card">
                            <div class="section-title">
                                <i class="fas fa-edit section-icon text-primary"></i>
                                Recommended Changes
                            </div>
                            <div class="row">
                                <% analysis.recommendedChanges.forEach(function(change) { %>
                                    <div class="col-md-6">
                                        <div class="list-item">
                                            <i class="fas fa-sync-alt text-primary list-icon"></i>
                                            <span><%= change %></span>
                                        </div>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                    </div>
                    <% } %>
                    
                    <!-- Targeted Advice -->
                    <div class="col-lg-12 fade-in">
                        <div class="section-card suggestions-card">
                            <div class="section-title">
                                <i class="fas fa-bullseye section-icon text-success"></i>
                                Targeted Advice for Your Goal
                                <% if (typeof jobTarget !== 'undefined' && jobTarget) { %>
                                    <small class="text-muted">(<%= jobTarget %>)</small>
                                <% } %>
                            </div>
                            <div style="background: #f8f9fa; border: 1px solid #dee2e6; padding: 1rem; border-radius: 0.375rem; margin-top: 1rem;">
                                <i class="fas fa-lightbulb me-2" style="color: #0d6efd;"></i>
                                <span style="color: #000;">
                                    <% if (analysis.targetedAdvice && analysis.targetedAdvice.trim() !== '') { %>
                                        <%= analysis.targetedAdvice %>
                                    <% } else { %>
                                        <% if (typeof jobTarget !== 'undefined' && jobTarget) { %>
                                            Based on your goal of targeting a <%= jobTarget %> position, focus on highlighting relevant skills and experiences that align with this role's requirements. Consider adding specific achievements and quantifiable results that demonstrate your expertise in this area.
                                        <% } else { %>
                                            Consider specifying a target role or job position to receive personalized advice tailored to your career goals.
                                        <% } %>
                                    <% } %>
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Footer Actions -->
                <div class="result-card fade-in text-center">
                    <h4 class="mb-3">Ready to improve your resume?</h4>
                    <p class="text-muted mb-4">
                        Use the insights above to optimize your resume for better ATS performance
                    </p>
                    <div class="d-flex justify-content-center gap-3">
                        <a href="/" class="back-btn">
                            <i class="fas fa-redo me-2"></i>Analyze Another Resume
                        </a>
                        <button onclick="window.print()" class="btn btn-outline-primary btn-lg">
                            <i class="fas fa-print me-2"></i>Print Results
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Animate progress ring on page load
        window.addEventListener('load', function() {
            const progressRing = document.getElementById('progressRing');
            if (progressRing) {
                setTimeout(() => {
                    progressRing.style.strokeDashoffset = progressRing.getAttribute('stroke-dashoffset');
                }, 100);
            }
        });
        
        // Add smooth scroll behavior
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({
                        behavior: 'smooth',
                        block: 'start'
                    });
                }
            });
        });
    </script>
    
    <!-- Helper functions for EJS -->
    <script>
        // These functions are used by EJS templates
        function getScoreColor(score) {
            if (score >= 80) return '#28a745';
            if (score >= 60) return '#17a2b8';
            if (score >= 40) return '#ffc107';
            return '#dc3545';
        }
        
        function getScoreClass(score) {
            if (score >= 80) return 'score-excellent';
            if (score >= 60) return 'score-good';
            if (score >= 40) return 'score-average';
            return 'score-poor';
        }
        
        function getScoreMessage(score) {
            if (score >= 80) return 'Excellent!';
            if (score >= 60) return 'Good';
            if (score >= 40) return 'Average';
            return 'Needs Improvement';
        }
        
        function getScoreDescription(score) {
            if (score >= 80) return 'Your resume is highly optimized for ATS systems and should perform well.';
            if (score >= 60) return 'Your resume has good ATS compatibility with room for improvement.';
            if (score >= 40) return 'Your resume needs some optimization to better pass ATS screening.';
            return 'Your resume requires significant improvements to pass ATS screening effectively.';
        }
    </script>
</body>
</html>
